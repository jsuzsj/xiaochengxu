/* components/login-modal/login-modal.wxss */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.box {
  width: 580rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.title {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
}
.desc {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}
.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
}
.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}
.avatar-placeholder {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
}
.nick {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-top: 32rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.phone {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-top: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 32rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
}
.skip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.4);
}
