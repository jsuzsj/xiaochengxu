/* pages/mine/mine.wxss */
.page {
  min-height: 100vh;
  background: #f6f6f6;
}
.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
  background: #fff;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}
.nickname {
  margin-top: 24rpx;
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.85);
}
.logout {
  width: 600rpx;
  margin: 60rpx auto 0;
  background: #fff;
  color: #e64340;
  font-size: 30rpx;
  border-radius: 12rpx;
}
