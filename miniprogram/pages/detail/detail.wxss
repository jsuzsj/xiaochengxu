/* pages/detail/detail.wxss */
.page {
  background: #fff;
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  line-height: 1.5;
}
.meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}
.cat {
  margin-right: 20rpx;
  color: #1aad19;
}
.content {
  margin-top: 32rpx;
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.8;
}
