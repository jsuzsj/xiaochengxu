/* pages/index/index.wxss */
page {
  background: #f6f6f6;
}
.page {
  min-height: 100vh;
}
.filters {
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
}
.chip {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.7);
  background: rgba(0, 0, 0, 0.05);
  border-radius: 30rpx;
}
.chip.active {
  background: #1aad19;
  color: #fff;
}
.tags {
  white-space: nowrap;
  padding: 0 24rpx 16rpx;
  background: #fff;
}
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  margin-right: 14rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 24rpx;
}
.tag.active {
  color: #1aad19;
  border-color: #1aad19;
}
.list {
  padding: 20rpx 24rpx;
}
.card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.cover {
  width: 180rpx;
  height: 130rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.title {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.9);
  line-height: 1.4;
}
.summary {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
}
.cat {
  margin-right: 16rpx;
  color: #1aad19;
}
.empty,
.loading {
  text-align: center;
  color: rgba(0, 0, 0, 0.4);
  font-size: 26rpx;
  padding: 60rpx 0;
}
